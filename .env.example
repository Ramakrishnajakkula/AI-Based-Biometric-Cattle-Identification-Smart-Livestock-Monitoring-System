# ===== MongoDB =====
MONGO_URI=mongodb://localhost:27017/cattle_monitoring

# ===== JWT =====
JWT_SECRET_KEY=change-this-to-a-random-secret-key

# ===== MQTT =====
MQTT_BROKER=localhost
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=

# ===== Flask =====
FLASK_ENV=development
FLASK_DEBUG=1
FLASK_PORT=5000

# ===== Twilio (SMS Alerts) =====
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_PHONE_NUMBER=+1234567890

# ===== Email (SMTP) =====
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password
ALERT_RECIPIENT=farmer@example.com

# ===== ML Model Paths =====
DETECTION_MODEL_PATH=ml/detection/weights/best.pt
RECOGNITION_MODEL_PATH=ml/recognition/weights/arcface_cattle.pth
HEALTH_MODEL_PATH=ml/health/weights/health_best.pt
